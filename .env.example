DATABASE_URL=postgresql+asyncpg://agentid:agentid@localhost:5432/agentid
SECRET_KEY=change-me-in-production

# Score settings
SCORE_RECALC_INTERVAL_MINUTES=60
GLOBAL_SCORE_MEAN=6.5
PEER_RATING_MIN_VOTES=10

# LLM Task Decomposition (optional — enables Claude-powered task DAG generation)
ANTHROPIC_API_KEY=sk-ant-...
# or: CLAUDE_API_KEY=sk-ant-...

# SDK settings (for client usage)
AGENTID_API_URL=https://api.agentid.dev
AGENTID_API_KEY=aid_key_...
AGENTID_DID=did:agentid:local:...
AGENTID_OWNER_KEY_PATH=~/.agentid/owner.pem
