# AgentID 生产环境配置
# 复制此文件为 .env 并填入实际值

# ── 数据库 ──────────────────────────────────────────────
POSTGRES_USER=agentid
POSTGRES_PASSWORD=你的强密码
POSTGRES_DB=agentid

# AgentID 数据库连接（docker-compose 内部使用）
#DATABASE_URL=postgresql+asyncpg://agentid:你的强密码@db:5432/agentid

# ── 安全 ────────────────────────────────────────────────
SECRET_KEY=你的64位强密钥（随机生成）

# ── CORS（允许 agentworker 访问）────────────────────────
# ⚠️ 替换为你的 agentworker 实际域名
ALLOWED_ORIGINS=https://aiagentworker.cc

# ── 版本 ────────────────────────────────────────────────
VERSION=latest
